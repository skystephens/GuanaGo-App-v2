{
  "name": "guiasai-b2b",
  "version": "1.0.0",
  "description": "Sistema de cotización B2B para agencias de viaje - GuiaSAI",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:wordpress": "tsc && vite build && npm run copy-to-wordpress",
    "copy-to-wordpress": "xcopy dist ..\\..\\wordpress-theme\\guiasai-agencias /E /I /Y",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx",
    "type-check": "tsc --noEmit",
    "export-tariffs": "node scripts/export-tariffs.js",
    "refresh-servicios": "node scripts/refresh-servicios.js"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "date-fns": "^2.30.0",
    "firebase": "^12.9.0",
    "lucide-react": "^0.263.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.13.0",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "terser": "^5.46.0",
    "typescript": "^5.3.3",
    "vite": "^6.4.1"
  }
}
